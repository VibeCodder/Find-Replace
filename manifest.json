{
  "manifest_version": 3,
  "name": "Find & Replace",
  "version": "2.0",
  "description": "Find & replace, form tools, and context menu on any webpage",
  "permissions": ["activeTab", "scripting", "storage", "contextMenus", "clipboardWrite", "clipboardRead"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Find & Replace",
    "default_icon": { "16":"icon.png","32":"icon.png","48":"icon.png","128":"icon.png" }
  },
  "icons": { "16":"icon.png","32":"icon.png","48":"icon.png","128":"icon.png" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }
  ]
}
